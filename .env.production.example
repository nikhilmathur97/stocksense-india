# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION Environment Variables — Indian Stock Market Platform
# Copy this to .env.production and fill in all values before deploying
# NEVER commit .env.production to git
# ═══════════════════════════════════════════════════════════════════════════════

# ── Angel One SmartAPI ────────────────────────────────────────────────────────
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PASSWORD=your_password_here
ANGEL_ONE_TOTP_SECRET=your_totp_secret_here

# ── Database (TimescaleDB on AWS RDS or EC2) ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://stockuser:STRONG_PASSWORD_HERE@timescaledb:5432/stockdb
DATABASE_HOST=timescaledb
DATABASE_PORT=5432
DATABASE_NAME=stockdb
DATABASE_USER=stockuser
DATABASE_PASSWORD=STRONG_PASSWORD_HERE

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REDIS_PASSWORD_HERE
REDIS_DB=0

# ── JWT Auth — CHANGE THIS to a random 64-char string ─────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_TO_64_CHAR_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2
ENVIRONMENT=production
DEBUG=false
# Replace with your actual domain
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Frontend (build-time args — must match your domain) ──────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_WS_URL=wss://your-domain.com/ws
NEXT_PUBLIC_APP_NAME=StockSense India

# ── Notifications (optional but recommended for prod alerts) ──────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SENDGRID_API_KEY=
FROM_EMAIL=

# ── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Data Pipeline ─────────────────────────────────────────────────────────────
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
TIMEZONE=Asia/Kolkata
SCREENER_INTERVAL_SECONDS=60

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=
