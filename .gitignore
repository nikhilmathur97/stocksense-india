*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# ── Virtual Environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── Environment Files (NEVER commit secrets) ──────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
