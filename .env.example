# ═══════════════════════════════════════════
# INDIAN STOCK MARKET PLATFORM — ENV CONFIG
# ═══════════════════════════════════════════

# ── Angel One SmartAPI ──────────────────────
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code
ANGEL_ONE_PASSWORD=your_password
ANGEL_ONE_TOTP_SECRET=your_totp_secret_base32

# ── Database (TimescaleDB) ──────────────────
DATABASE_URL=postgresql+asyncpg://stockuser:stockpass@localhost:5432/stockdb
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=stockdb
DATABASE_USER=stockuser
DATABASE_PASSWORD=stockpass

# ── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT Auth ────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Backend ─────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=StockSense India

# ── Telegram Bot (Alerts) ───────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Email (SendGrid) ────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=alerts@yourdomain.com

# ── WhatsApp (Twilio) ───────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── AWS S3 (Backups) ────────────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your-backup-bucket
AWS_REGION=ap-south-1

# ── Rate Limiting ───────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# ── Data Pipeline ───────────────────────────
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
TIMEZONE=Asia/Kolkata
SCREENER_INTERVAL_SECONDS=60
OPTIONS_INTERVAL_SECONDS=300
